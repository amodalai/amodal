{
  "name": "@amodalai/studio",
  "version": "0.3.56",
  "description": "Agent editor — draft workspace, file browser, and publish flow for amodal agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amodalai/amodal.git",
    "directory": "packages/studio"
  },
  "homepage": "https://github.com/amodalai/amodal",
  "bugs": {
    "url": "https://github.com/amodalai/amodal/issues"
  },
  "type": "module",
  "main": "dist-server/src/lib/index.js",
  "types": "dist-server/src/lib/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist-server/src/lib/index.d.ts",
      "import": "./dist-server/src/lib/index.js"
    },
    "./server": {
      "types": "./dist-server/src/server/studio-server.d.ts",
      "import": "./dist-server/studio-server.js"
    },
    "./app": "./src/App.tsx",
    "./events": "./src/contexts/StudioEventsContext.tsx",
    "./config": "./src/contexts/StudioConfigContext.tsx",
    "./styles": "./src/index.css"
  },
  "files": [
    "dist",
    "dist-server",
    "src"
  ],
  "scripts": {
    "dev": "tsx src/server/bin.ts",
    "build": "vite build && node scripts/build-server.js",
    "start": "node dist-server/bin.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@amodalai/core": "workspace:*",
    "@amodalai/db": "workspace:*",
    "@amodalai/react": "workspace:*",
    "@amodalai/runtime": "workspace:*",
    "@amodalai/types": "workspace:*",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@hono/node-server": "^2.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "hono": "^4.12.17",
    "lucide-react": "^1.14.0",
    "pg": "^8.13.1",
    "postcss": "^8.5.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
