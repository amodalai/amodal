{
  "name": "@amodalai/studio",
  "version": "0.3.13",
  "description": "Agent editor — draft workspace, file browser, and publish flow for amodal agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amodalai/amodal.git",
    "directory": "packages/studio"
  },
  "homepage": "https://github.com/amodalai/amodal",
  "bugs": {
    "url": "https://github.com/amodalai/amodal/issues"
  },
  "type": "module",
  "main": "dist-server/src/lib/index.js",
  "types": "dist-server/src/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-server/src/lib/index.d.ts",
      "import": "./dist-server/src/lib/index.js"
    },
    "./server": {
      "import": "./dist-server/studio-server.js"
    },
    "./app": "./src/App.tsx",
    "./events": "./src/contexts/StudioEventsContext.tsx",
    "./config": "./src/contexts/StudioConfigContext.tsx",
    "./styles": "./src/index.css"
  },
  "files": [
    "dist",
    "dist-server",
    "src"
  ],
  "scripts": {
    "dev": "tsx src/server/studio-server.ts",
    "build": "vite build && node scripts/build-server.js",
    "start": "node dist-server/studio-server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@amodalai/db": "workspace:*",
    "@amodalai/react": "workspace:*",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.7.0",
    "lucide-react": "^0.469.0",
    "pg": "^8.13.1",
    "postcss": "^8.4.47",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.1"
  }
}
