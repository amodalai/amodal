{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-server",
    "noEmit": false,
    "declaration": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler"
  },
  "include": ["src/server/**/*.ts", "src/lib/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
