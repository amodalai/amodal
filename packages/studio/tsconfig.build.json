{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "composite": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "jsx": "preserve",
    "outDir": "dist-server",
    "types": ["node"]
  },
  "include": ["src/lib/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-server", "src/**/*.test.ts"],
  "references": [{ "path": "../db" }]
}
