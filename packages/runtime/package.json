{
  "name": "@amodalai/runtime",
  "version": "0.1.26",
  "description": "Agent Runtime Platform — HTTP server for repo and platform modes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amodalai/amodal.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://github.com/amodalai/amodal",
  "bugs": {
    "url": "https://github.com/amodalai/amodal/issues"
  },
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "node ../../scripts/build_package.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:smoke": "vitest run src/__fixtures__/smoke.test.ts",
    "test:ci": "pnpm --filter @amodalai/core run build && vitest run",
    "typecheck": "tsc --emitDeclarationOnly",
    "start": "node dist/src/index.js",
    "start:dev": "node --env-file=.env dist/src/index.js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/google": "^3.0.58",
    "@ai-sdk/openai": "^3.0.50",
    "@amodalai/core": "workspace:*",
    "@amodalai/types": "workspace:*",
    "@anthropic-ai/sdk": "^0.39.0",
    "@electric-sql/pglite": "^0.3.15",
    "ai": "^6.0.145",
    "drizzle-orm": "^0.45.2",
    "esbuild": "0.25.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "jose": "^6.0.0",
    "node-cron": "^3.0.3",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.1.1",
    "supertest": "^7.0.0",
    "typescript": "^5.3.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
