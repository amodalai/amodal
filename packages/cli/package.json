    "ink": "^7.0.2",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "open": "^11.0.0",
    "prompts": "^2.4.2",
    "react": "^19.2.5",
    "yargs": "^18.0.0",
    "@amodalai/runtime-app": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9",
