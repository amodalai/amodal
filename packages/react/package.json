{
  "name": "@amodalai/react",
  "version": "0.3.49",
  "description": "React bindings for Amodal agent runtime",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amodalai/amodal.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/amodalai/amodal",
  "bugs": {
    "url": "https://github.com/amodalai/amodal/issues"
  },
  "type": "module",
  "main": "dist/react.js",
  "module": "dist/react.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./widget": {
      "types": "./dist/widget/index.d.ts",
      "import": "./dist/widget.js",
      "default": "./dist/widget.js"
    },
    "./widget/style.css": "./dist/react.css",
    "./style.css": "./dist/react.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "msw": "^2.14.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "react-markdown": "^10.1.0"
  }
}
