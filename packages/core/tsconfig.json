{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "composite": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@amodalai/core": ["./src/index.ts"],
      "@amodalai/types": ["../types/src/index.ts"]
    }
  },
  "references": [{ "path": "../types" }],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts"]
}
