{
  "name": "@amodalai/chat-widget",
  "version": "0.1.0",
  "description": "Embeddable chat widget for Amodal agents",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/amodalai/amodal.git", "directory": "packages/chat-widget" },
  "homepage": "https://github.com/amodalai/amodal",
  "bugs": { "url": "https://github.com/amodalai/amodal/issues" },
  "type": "module",
  "main": "dist/chat-widget.js",
  "module": "dist/chat-widget.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/chat-widget.js",
      "default": "./dist/chat-widget.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./style.css": "./dist/chat-widget.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.1.1"
  }
}
