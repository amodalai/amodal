{
  "name": "@amodalai/monorepo",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "amodal": "node packages/cli/dist/src/main.js",
    "dev:build": "pnpm run build && pnpm --filter @amodalai/runtime-app run build",
    "build": "pnpm -r --filter '!@amodalai/docs' run build",
    "test": "pnpm -r run test",
    "test:ci": "pnpm -r run test:ci",
    "lint": "eslint . --cache && node scripts/check-publishable-deps.js",
    "typecheck": "pnpm --filter @amodalai/db run build && pnpm -r run typecheck",
    "bundle": "pnpm -r run build && cd packages/runtime-app && npx vite build --outDir ../../bundle/app && cd ../.. && node esbuild.config.js",
    "clean": "pnpm -r exec rm -rf dist",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:release": "changeset publish --no-git-tag",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --cache --fix",
    "*.{json,yml,yaml,md}": "prettier --write"
  },
  "overrides": {
    "ink": "npm:@jrichman/ink@6.4.10",
    "wrap-ansi": "9.0.2",
    "cliui": {
      "wrap-ansi": "7.0.0"
    },
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/eslint-plugin": "^1.6.16",
    "esbuild": "0.28.0",
    "esbuild-plugin-wasm": "^1.1.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-headers": "^1.3.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "husky": "^9.1.0",
    "lint-staged": "^16.4.0",
    "vitest": "^4.1.5"
  }
}
